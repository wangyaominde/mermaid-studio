{
  "name": "mermaid-studio",
  "version": "2.0.0",
  "description": "Mermaid.js diagram editor with MCP server — Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create mermaid-studio-db",
    "db:migrate": "wrangler d1 migrations apply mermaid-studio-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply mermaid-studio-db --local"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "wrangler": "^4.81.0"
  }
}
